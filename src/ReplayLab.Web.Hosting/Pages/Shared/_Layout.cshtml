<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReplayLab Web</title>
    <link rel="stylesheet" href="~/_content/ReplayLab.Web.Hosting/lib/tabulator/css/tabulator.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/ReplayLab.Web.Hosting/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="shell-header">
        <div class="shell-frame">
            <a class="brand" asp-area="" asp-page="/Index">ReplayLab Web</a>
            <p class="shell-caption">Local-only Razor Pages UI for CSV inspection and selected-row mock replay.</p>
        </div>
    </header>

    <div class="shell-frame">
        <main role="main" class="shell-main">
            @RenderBody()
        </main>
    </div>
    <script src="~/_content/ReplayLab.Web.Hosting/lib/tabulator/js/tabulator.min.js" asp-append-version="true"></script>
    <script src="~/_content/ReplayLab.Web.Hosting/js/replay-grid.js" asp-append-version="true"></script>
</body>
</html>
