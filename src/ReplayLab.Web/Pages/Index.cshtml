@page
@model ReplayLab.Web.Pages.IndexModel
@{
    ViewData["Title"] = "ReplayLab Web";
}

<section class="workspace-panel">
    <div class="data-toolbar" aria-label="Replay controls">
        <form method="post" asp-page="/Index" enctype="multipart/form-data" class="upload-form">
            @Html.AntiForgeryToken()
            <label class="file-picker">
                <span class="file-picker-button">Choose file</span>
                <input asp-for="Upload" class="file-input" type="file" accept=".csv,text/csv" />
            </label>
            <span id="selected-file-name" class="selected-file-name">@(string.IsNullOrWhiteSpace(Model.UploadedFileName) ? "No file selected" : Model.UploadedFileName)</span>
        </form>

        <div class="toolbar-actions">
            <span id="selected-count" class="selection-count" data-total="@Model.Rows.Count">@Model.SelectedRowCount selected / @Model.Rows.Count row(s)</span>
            <button type="button" id="select-all" class="tool-button" disabled="@(Model.Rows.Count == 0)">Select all</button>
            <button type="button" id="deselect-all" class="tool-button" disabled="@(Model.Rows.Count == 0)">Deselect all</button>
            <button type="button" id="columns-menu" class="tool-button" disabled="@(Model.Rows.Count == 0)">Columns</button>
            <button type="submit" id="replay-selected" form="replay-form" class="action" disabled="@(Model.SelectedRowCount == 0)">Send selected</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="feedback error" role="alert">@Model.ErrorMessage</div>
    }

    <div id="resend-warning" class="feedback warning" role="alert" @(string.IsNullOrWhiteSpace(Model.WarningMessage) ? "hidden" : "")>@Model.WarningMessage</div>

    @if (Model.Summary is not null)
    {
        <div class="feedback summary" role="status">
            Sent @Model.Summary.Total selected row(s): @Model.Summary.Succeeded succeeded, @Model.Summary.Failed failed.
        </div>
    }

    <form id="replay-form" method="post" asp-page-handler="Replay">
        @Html.AntiForgeryToken()
        <input asp-for="UploadedCsv" type="hidden" />
        <input asp-for="UploadedFileName" type="hidden" />
        <input id="ReplayStateJson" name="ReplayStateJson" type="hidden" value="@Model.GridStateJson" />
        <input id="ConfirmResendSucceeded" name="ConfirmResendSucceeded" type="hidden" value="false" />
        <div id="selected-message-fields" aria-hidden="true"></div>
    </form>

    <div class="grid-shell">
        <div id="replay-grid" class="replay-grid"></div>
        @if (Model.Rows.Count == 0)
        {
            <div class="empty-state">Load a CSV file to populate the replay grid.</div>
        }
    </div>
</section>

<script id="replay-grid-data" type="application/json">
@Html.Raw(Model.GridStateJson)
</script>
